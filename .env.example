# Environment Variables Template

# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# RPC ENDPOINTS
# =============================================================================

# Ethereum RPC URL (mainnet)
# Get free API key from https://infura.io or https://alchemy.com
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Solana RPC URL (mainnet-beta)
# Get free API key from https://quicknode.com or use public endpoint
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Network environment: mainnet, testnet, devnet, local
# - mainnet: Production blockchain networks
# - testnet: Ethereum testnets (Goerli, Sepolia)
# - devnet: Solana devnet for testing
# - local: Local development (Hardhat/Anvil)
NETWORK=devnet

# Chain ID for Ethereum-compatible chains
# 1 = Ethereum Mainnet
# 5 = Goerli Testnet
# 11155111 = Sepolia Testnet
# 31337 = Local Hardhat
CHAIN_ID=31337

# =============================================================================
# IPFS CONFIGURATION
# =============================================================================

# IPFS Gateway URL for retrieving content
# Options: https://ipfs.io, https://cloudflare-ipfs.com, https://gateway.pinata.cloud
IPFS_GATEWAY=https://cloudflare-ipfs.com

# IPFS HTTP API URL for adding/pinning content
# Run local node with: docker run -d -p 5001:5001 ipfs/kubo
IPFS_API_URL=http://localhost:5001/api/v0

# Pinata API Key (optional, for pinning service)
# Get from https://pinata.cloud
PINATA_API_KEY=your_pinata_api_key_here

# Pinata Secret Key (optional, for pinning service)
PINATA_SECRET_KEY=your_pinata_secret_key_here

# =============================================================================
# LOGGING
# =============================================================================

# Rust log level: trace, debug, info, warn, error
# Examples:
# - RUST_LOG=info (general info messages)
# - RUST_LOG=xorion_sdk=debug,xorion_zk=trace (granular control)
# - RUST_LOG=off (disable logging)
RUST_LOG=debug

# Log format: json, pretty, compact
RUST_LOG_FORMAT=pretty

# =============================================================================
# SECURITY
# =============================================================================

# Wallet encryption password (for local key storage)
# IMPORTANT: Use a strong, unique password
WALLET_ENCRYPTION_PASSWORD=change_this_strong_password

# Session timeout in seconds (default: 3600 = 1 hour)
SESSION_TIMEOUT=3600

# Enable hardware wallet support (Ledger, Trezor)
HARDWARE_WALLET_ENABLED=true

# =============================================================================
# ZK-SNARKS CONFIGURATION
# =============================================================================

# Path to zk-SNARK circuit files
ZK_CIRCUITS_PATH=./circuits

# Path to proving keys
ZK_PROVING_KEYS_PATH=./zkeys

# Enable proof caching (reduces proving time for repeated operations)
ZK_PROOF_CACHING=true

# Cache TTL in seconds (default: 300 = 5 minutes)
ZK_CACHE_TTL=300

# =============================================================================
# DATABASE
# =============================================================================

# SQLite database path for local storage
DATABASE_URL=./data/xorion.db

# Connection pool size (for production deployments)
DB_POOL_SIZE=5

# =============================================================================
# API SERVER (Optional, for backend services)
# =============================================================================

# Server host
API_HOST=127.0.0.1

# Server port
API_PORT=8080

# Enable CORS (for web applications)
CORS_ENABLED=true

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# RATE LIMITING
# =============================================================================

# Maximum requests per second
RATE_LIMIT_RPS=100

# Burst size
RATE_LIMIT_BURST=200

# =============================================================================
# MONITORING & ANALYTICS (Optional)
# =============================================================================

# Sentry DSN for error tracking
# Get from https://sentry.io
SENTRY_DSN=

# Enable performance monitoring
PERF_MONITORING=false

# Analytics endpoint (privacy-preserving)
ANALYTICS_ENDPOINT=

# =============================================================================
# DEVELOPMENT FLAGS
# =============================================================================

# Skip SSL certificate verification (development only!)
SKIP_SSL_VERIFY=false

# Enable verbose error messages
DEBUG_MODE=true

# Mock external services (for offline testing)
MOCK_SERVICES=false

# =============================================================================
# EXAMPLE VALUES FOR TESTING
# =============================================================================

# For Ethereum Sepolia testnet:
# ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# CHAIN_ID=11155111
# NETWORK=testnet

# For Solana devnet:
# SOL_RPC_URL=https://api.devnet.solana.com
# NETWORK=devnet

# For local development:
# ETH_RPC_URL=http://localhost:8545
# SOL_RPC_URL=http://localhost:8899
# NETWORK=local
